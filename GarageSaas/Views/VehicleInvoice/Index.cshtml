@model List<SignupAPI.Models.VehicleInvoiceListItem>

@{
    ViewData["Title"] = "Vehicle Invoices";
}

<div class="container-fluid mt-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="mb-1">Vehicle Invoices</h1>
            <div class="text-muted small">Manage customer invoices, payment status and vehicle billing.</div>
        </div>

        <a asp-action="AddEdit" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Add Invoice
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model?.Count > 0)
    {
        <div class="card shadow-sm">
            <div class="card-body border-bottom">
                <div class="row g-3 align-items-center">
                    <div class="col-12 col-md-6">
                        <h5 class="mb-0">Invoice list</h5>
                    </div>
                    <div class="col-12 col-md-6 text-md-end">
                        <span class="badge bg-secondary">@Model.Count invoice(s)</span>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Invoice #</th>
                            <th>Date</th>
                            <th>Customer</th>
                            <th>Contact</th>
                            <th>Vehicle</th>
                            <th class="text-end">Total</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var invoice in Model)
                        {
                            var isPaid = invoice.Paid == true;
                            var total = invoice.Total.ToString() ?? invoice.InvoiceAmount ?? 0.ToString();

                            <tr>
                                <td>
                                    <strong>@(!string.IsNullOrWhiteSpace(invoice.InvoiceNumber) ? invoice.InvoiceNumber : $"INV-{invoice.Id}")</strong>
                                </td>

                                <td>
                                    @(invoice.InvoiceDate.HasValue
                                        ? invoice.InvoiceDate.Value.ToString("dd/MM/yyyy")
                                        : "")
                                </td>

                                <td>
                                    <div class="fw-semibold">@invoice.CustomerName</div>
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(invoice.PhoneNumber))
                                    {
                                        <div>
                                            <i class="bi bi-telephone me-1"></i>@invoice.PhoneNumber
                                        </div>
                                    }

                                    @if (!string.IsNullOrWhiteSpace(invoice.EmailAddress))
                                    {
                                        <div class="text-muted small">
                                            <i class="bi bi-envelope me-1"></i>@invoice.EmailAddress
                                        </div>
                                    }
                                </td>

                                <td>
                                    @if (!string.IsNullOrWhiteSpace(invoice.VehicleRegistration))
                                    {
                                        <span class="badge bg-light text-dark border">@invoice.VehicleRegistration</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No vehicle</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <span class="fw-semibold">€@invoice.Total</span>
                                </td>

                                <td>
                                    @if (isPaid)
                                    {
                                        <span class="badge bg-success">Paid</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Not Paid</span>
                                    }
                                </td>

                                <td>
                                    @(invoice.DateDue.HasValue
                                        ? invoice.DateDue.Value.ToString("dd/MM/yyyy")
                                        : "")
                                </td>

                                <td class="text-end">
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a asp-action="Detail"
                                           asp-route-id="@invoice.Id"
                                           class="btn btn-outline-primary"
                                           title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="AddEdit"
                                           asp-route-id="@invoice.Id"
                                           class="btn btn-outline-warning"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <button type="button"
                                                class="btn btn-outline-danger"
                                                title="Delete"
                                                onclick="deleteInvoice(@invoice.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <i class="bi bi-receipt fs-1 text-muted"></i>
                <h5 class="mt-3">No invoices found</h5>
                <p class="text-muted mb-3">New invoices are created as <strong>Not Paid</strong> by default.</p>
                <a asp-action="AddEdit" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i> Create invoice
                </a>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function deleteInvoice(invoiceId) {
            if (!confirm('Are you sure you want to delete this invoice?')) {
                return;
            }

            fetch(`/VehicleInvoice/Delete?invoiceId=${invoiceId}`, {
                method: 'DELETE',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.status === 'Success') {
                    location.reload();
                } else {
                    alert('Error: ' + (data.message || 'Delete failed.'));
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Delete failed.');
            });
        }
    </script>
}