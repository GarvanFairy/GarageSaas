@using System.Text.Json
@using GarageSaas.Services.Models
@model SignupAPI.Models.VehicleInvoice

@{
    ViewData["Title"] = Model?.Id == 0 || Model?.Id == null ? "Create Invoice" : "Edit Invoice";
    var vehicleOptions = ViewData["VehicleOptions"] as List<VehicleDropdownItem> ?? new List<VehicleDropdownItem>();
    var vehiclesJson = JsonSerializer.Serialize(vehicleOptions);
    var selectedVehicleId = Model?.VehicleId ?? 0;
}

<div class="container-fluid mt-4">
    <h1>@ViewData["Title"]</h1>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form asp-action="AddEdit" asp-controller="VehicleInvoice" method="post" autocomplete="off">
        @Html.HiddenFor(model => model.Id)

        <!-- ================= INVOICE DETAILS ================= -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">Invoice Details</h5>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label">Invoice Number</label>
                        <input asp-for="InvoiceNumber" class="form-control" placeholder="INV-001" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Invoice Date</label>
                        <input asp-for="InvoiceDate" class="form-control" type="date" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Invoice Type</label>
                        <input asp-for="InvoiceType" class="form-control" placeholder="e.g., Service, Repair" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Invoice Status</label>
                        <select asp-for="InvoiceStatus" class="form-select">
                            <option value="">-- Select status --</option>
                            <option value="Draft">Draft</option>
                            <option value="Issued">Issued</option>
                            <option value="Overdue">Overdue</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Description</label>
                        <textarea asp-for="InvoiceDescription" class="form-control" rows="3" placeholder="Enter invoice description..."></textarea>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Comments</label>
                        <textarea asp-for="Comment" class="form-control" rows="2" placeholder="Add any additional comments..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================= CUSTOMER & VEHICLE ================= -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">Customer & Vehicle Information</h5>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label">Customer</label>
                        <select asp-for="GarageBusinessCustomerId"
                                asp-items="@(ViewData["Customers"] as List<SelectListItem>)"
                                class="form-select">
                            <option value="">-- Select customer --</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Vehicle</label>

                        <select asp-for="VehicleId"
                                class="form-select"
                                id="VehicleId">
                            <option value="">-- Select vehicle --</option>
                        </select>
                    </div>

                    <input asp-for="CustomerId" type="hidden" id="CustomerId" />

                    <div class="col-md-6">
                        <label class="form-label">Work Quote ID</label>
                        <input asp-for="WorkQuoteId" class="form-control" type="number" id="WorkQuoteId" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ================= WORK ITEM ================= -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">Work Item</h5>

                <div class="row g-4">
                    <div class="col-md-12">
                        <label class="form-label">New Work Item Instructions</label>
                        <textarea id="NewWorkItemInstructions" class="form-control" rows="3" placeholder="Enter repair instructions for the work item"></textarea>
                    </div>
                    <div class="col-md-12">
                        <button type="button" class="btn btn-outline-primary" id="createWorkItemButton">
                            <i class="bi bi-plus-circle"></i> Create Work Item and Attach to Invoice
                        </button>
                        <div id="workItemStatus" class="mt-3"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================= COSTS ================= -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">Costs Breakdown</h5>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label">Labour</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="Labour" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Paint</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="Paint" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Environment Cost</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="EnvironmentCost" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Car Hire</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="CarHire" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Sundry Expenses</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="SundryExpenses" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Invoice Amount</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="InvoiceAmount" class="form-control" placeholder="0.00" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================= TOTALS ================= -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">Totals</h5>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label">Sub Total</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="SubTotal" class="form-control" type="number" step="0.01" placeholder="0.00" readonly />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Tax</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="Tax" class="form-control" type="number" step="0.01" placeholder="0.00" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">VAT (23.5%)</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="Vat" class="form-control" type="number" step="0.01" placeholder="0.00" readonly />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Total</label>
                        <div class="input-group">
                            <span class="input-group-text">€</span>
                            <input asp-for="Total" class="form-control" type="number" step="0.01" placeholder="0.00" readonly />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">String Total</label>
                        <input asp-for="StrTotal" class="form-control" placeholder="Total as text" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ================= PAYMENT ================= -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="mb-3">Payment Information</h5>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="form-check">
                            <input type="hidden" name="Paid" value="false" />
                            <input class="form-check-input" type="checkbox" name="Paid" value="true" id="chkPaid" @(Model?.Paid == true ? "checked" : "") />
                            <label class="form-check-label" for="chkPaid">
                                Marked as Paid
                            </label>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Due Date</label>
                        <input asp-for="DateDue" class="form-control" type="date" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Paid Date</label>
                        <input asp-for="DatePaid" class="form-control" type="date" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Payment Received Date</label>
                        <input asp-for="PaidDate" class="form-control" type="date" />
                    </div>
                </div>
            </div>
        </div>

        <!-- ================= ACTIONS ================= -->
        <div class="d-flex gap-2 mb-4">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> @(Model?.Id > 0 ? "Update" : "Create") Invoice
            </button>
            <a class="btn btn-light" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

<script>
    const allVehicleOptions = @Html.Raw(vehiclesJson);
    const customerSelect = document.getElementById("GarageBusinessCustomerId");
    const vehicleSelect = document.getElementById("VehicleId");
    const customerHidden = document.getElementById("CustomerId");
    const selectedVehicleId = @selectedVehicleId;

    function syncCustomerId() {
        if (customerHidden && customerSelect) {
            customerHidden.value = customerSelect.value || "";
        }
    }

    function refreshVehicleOptions() {
        if (!vehicleSelect) return;

        const currentCustomerId = customerSelect ? customerSelect.value : "";
        vehicleSelect.innerHTML = '<option value="">-- Select vehicle --</option>';

        if (!currentCustomerId) {
            return;
        }

        const filtered = allVehicleOptions.filter(v => String(v.GarageBusinessCustomerId) === currentCustomerId);

        filtered.forEach(v => {
            const option = document.createElement("option");
            option.value = v.Id;
            option.text = v.Text;
            if (v.Id === selectedVehicleId) {
                option.selected = true;
            }
            vehicleSelect.appendChild(option);
        });
    }

    function parseCurrencyField(name) {
        const field = document.querySelector(`[name="${name}"]`);
        if (!field) return 0;
        const value = parseFloat(field.value);
        return Number.isFinite(value) ? value : 0;
    }

    function setCurrencyField(name, value) {
        const field = document.querySelector(`[name="${name}"]`);
        if (!field) return;
        field.value = value.toFixed(2);
    }

    function calculateInvoiceTotals() {
        const subtotal = parseCurrencyField("Labour")
            + parseCurrencyField("Paint")
            + parseCurrencyField("EnvironmentCost")
            + parseCurrencyField("CarHire")
            + parseCurrencyField("SundryExpenses");

        const vat = parseFloat((subtotal * 0.235).toFixed(2));
        const total = parseFloat((subtotal + vat).toFixed(2));

        setCurrencyField("SubTotal", subtotal);
        setCurrencyField("Vat", vat);
        setCurrencyField("Total", total);
    }

    document.addEventListener("DOMContentLoaded", function () {
        if (!customerSelect) return;

        const costInputs = ["Labour", "Paint", "EnvironmentCost", "CarHire", "SundryExpenses"];
        const createWorkItemButton = document.getElementById("createWorkItemButton");
        const workItemStatus = document.getElementById("workItemStatus");
        const newWorkItemInstructions = document.getElementById("NewWorkItemInstructions");

        function setStatus(message, type = "info") {
            if (!workItemStatus) return;
            workItemStatus.innerHTML = `<div class="alert alert-${type} py-2">${message}</div>`;
        }

        async function createWorkItemAndWorkQuote() {
            if (!customerSelect || !vehicleSelect) {
                setStatus("Select a customer and vehicle first.", "warning");
                return;
            }

            const customerId = customerSelect.value;
            const vehicleId = vehicleSelect.value;
            const instructions = newWorkItemInstructions?.value?.trim();

            if (!customerId || !vehicleId || !instructions) {
                setStatus("Customer, vehicle and work item instructions are required.", "warning");
                return;
            }

            try {
                setStatus("Creating work item...", "info");

                const workItemResponse = await fetch("/WorkItem/AddWorkItem", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        repairInstructions: instructions,
                        vehicleId: Number(vehicleId),
                        customerId: Number(customerId)
                    })
                });

                const workItemData = await workItemResponse.json();
                if (workItemData.status !== "Success") {
                    setStatus(workItemData.message || "Failed to create work item.", "danger");
                    return;
                }

                const workItemId = workItemData.data?.id;
                if (!workItemId) {
                    setStatus("Work item was created but no ID was returned.", "danger");
                    return;
                }

                setStatus("Creating work quote and attaching the work item...", "info");

                const workQuoteResponse = await fetch("/WorkQuote/AddWorkQuote3", {
                    method: "POST",
                    headers: { "Content-Type": "application/json" },
                    body: JSON.stringify({
                        workItemId: workItemId,
                        vehicleId: Number(vehicleId),
                        customerId: Number(customerId),
                        garageBusinessCustomerId: Number(customerId),
                        workQuoteDate: new Date().toISOString().slice(0, 10)
                    })
                });

                const workQuoteData = await workQuoteResponse.json();
                if (workQuoteData.status !== "Success") {
                    setStatus(workQuoteData.message || "Failed to create work quote.", "danger");
                    return;
                }

                const createdQuote = workQuoteData.data;
                const workQuoteIdField = document.getElementById("WorkQuoteId");
                if (workQuoteIdField) {
                    workQuoteIdField.value = createdQuote.workQuoteId || createdQuote.WorkQuoteId || createdQuote.id || createdQuote.Id || "";
                }

                setStatus(`Work item created and added to invoice via Work Quote ID ${workQuoteIdField?.value}.`, "success");
            }
            catch (error) {
                console.error(error);
                setStatus("An unexpected error occurred while creating the work item.", "danger");
            }
        }

        if (createWorkItemButton) {
            createWorkItemButton.addEventListener("click", createWorkItemAndWorkQuote);
        }

        customerSelect.addEventListener("change", function () {
            syncCustomerId();
            refreshVehicleOptions();
        });

        costInputs.forEach(name => {
            const field = document.querySelector(`[name="${name}"]`);
            if (!field) return;
            field.addEventListener("input", calculateInvoiceTotals);
        });

        syncCustomerId();
        refreshVehicleOptions();
        calculateInvoiceTotals();
    });
</script>
