@model SignupAPI.Models.GarageCustomerWithListVehiclesVM

@{
    var isEdit = Model?.Customer?.Id > 0;
    var customerName = $"{Model?.Customer?.GarageCustomerForename} {Model?.Customer?.GarageCustomerSurname}".Trim();
    var displayName = string.IsNullOrWhiteSpace(customerName) ? "New customer" : customerName;
    var initial = string.IsNullOrWhiteSpace(displayName) ? "?" : displayName.Substring(0, 1).ToUpperInvariant();
    var vehicleCount = Model?.Vehicles?.Count ?? 0;
    var garageBusinessId = TempData["GarageBusinessId"];
    var userId = TempData["userId"];
    TempData.Keep("GarageBusinessId");
    TempData.Keep("userId");

    ViewData["Title"] = isEdit ? "Edit Garage Customer" : "Add Garage Customer";
}

<section class="page-title-row edit-customer-header">
    <div>
        <p class="eyebrow mb-2">Customer record</p>
        <h1>@(isEdit ? "Edit customer" : "Add customer")</h1>
        <p class="text-muted mb-0">
            @(isEdit ? "Update customer details, contact information, and linked vehicles." : "Create a customer profile for your garage directory.")
        </p>
    </div>

    <div class="page-actions">
        <a class="btn btn-outline-secondary"
           asp-action="GarageCustomersList"
           asp-route-garageBusinessId="@garageBusinessId"
           asp-route-userId="@userId">
            <i class="bi bi-arrow-left me-2"></i>Customers
        </a>
    </div>
</section>

<form asp-action="AddUpdateGarageCustomer"
      asp-controller="GarageCustomers"
      method="post"
      autocomplete="off">

    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Customer.Id" />

    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

    <section class="edit-customer-grid">
        <div class="workspace-panel edit-form-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow mb-1">Profile</p>
                    <h2>Customer details</h2>
                </div>
            </div>

            <div class="form-section">
                <div class="section-heading">
                    <span><i class="bi bi-person"></i></span>
                    <div>
                        <h3>Name</h3>
                        <p>Use the customer name shown in lists and invoices.</p>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="Customer.GarageCustomerForename" class="form-label">Forename</label>
                        <input asp-for="Customer.GarageCustomerForename" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerForename" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Customer.GarageCustomerSurname" class="form-label">Surname</label>
                        <input asp-for="Customer.GarageCustomerSurname" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerSurname" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="section-heading">
                    <span><i class="bi bi-geo-alt"></i></span>
                    <div>
                        <h3>Address</h3>
                        <p>Keep location details ready for customer records.</p>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-12">
                        <label asp-for="Customer.GarageCustomerAddressline1" class="form-label">Address line 1</label>
                        <input asp-for="Customer.GarageCustomerAddressline1" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerAddressline1" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Customer.GarageCustomerAddressline2" class="form-label">Address line 2</label>
                        <input asp-for="Customer.GarageCustomerAddressline2" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerAddressline2" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Customer.GarageCustomerAddressline3" class="form-label">Address line 3</label>
                        <input asp-for="Customer.GarageCustomerAddressline3" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerAddressline3" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Customer.GarageCustomerAddressline4" class="form-label">Address line 4</label>
                        <input asp-for="Customer.GarageCustomerAddressline4" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerAddressline4" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Customer.GarageCustomerPostcode" class="form-label">Postcode</label>
                        <input asp-for="Customer.GarageCustomerPostcode" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerPostcode" class="text-danger"></span>
                    </div>
                </div>
            </div>

            <div class="form-section">
                <div class="section-heading">
                    <span><i class="bi bi-chat-dots"></i></span>
                    <div>
                        <h3>Contact</h3>
                        <p>Add the best ways to reach this customer.</p>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="Customer.GarageCustomerMobileNumber" class="form-label">Mobile number</label>
                        <input asp-for="Customer.GarageCustomerMobileNumber" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerMobileNumber" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="Customer.GarageCustomerPhoneNumber" class="form-label">Phone number</label>
                        <input asp-for="Customer.GarageCustomerPhoneNumber" class="form-control" />
                        <span asp-validation-for="Customer.GarageCustomerPhoneNumber" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Customer.GarageCustomerEmailAddress" class="form-label">Email address</label>
                        <input asp-for="Customer.GarageCustomerEmailAddress" class="form-control" type="email" />
                        <span asp-validation-for="Customer.GarageCustomerEmailAddress" class="text-danger"></span>
                    </div>
                </div>
            </div>
        </div>

        <aside class="edit-customer-side">
            <div class="workspace-panel customer-record-card">
                <div class="customer-record-main">
                    <span class="customer-avatar customer-record-avatar">@initial</span>
                    <div>
                        <p class="eyebrow mb-1">Current record</p>
                        <h2>@displayName</h2>
                        <span class="status-pill">
                            <i class="bi bi-circle-fill"></i>@(isEdit ? "Saved customer" : "Draft customer")
                        </span>
                    </div>
                </div>

                <div class="record-stat-grid">
                    <div>
                        <span>Customer ID</span>
                        <strong>@(isEdit ? Model.Customer.Id.ToString() : "New")</strong>
                    </div>
                    <div>
                        <span>Vehicles</span>
                        <strong>@vehicleCount</strong>
                    </div>
                </div>
            </div>

            @if (isEdit)
            {
                <div class="workspace-panel linked-vehicles-panel">
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow mb-1">Linked assets</p>
                            <h2>Vehicles</h2>
                        </div>

                        <a class="btn btn-sm btn-primary"
                           asp-controller="CustomerVehicle"
                           asp-action="DisplayAddCustomerVehicle"
                           asp-route-garageBusinessId="@garageBusinessId"
                           asp-route-userId="@userId">
                            <i class="bi bi-plus-lg"></i>
                        </a>
                    </div>

                    @if (Model?.Vehicles != null && Model.Vehicles.Any())
                    {
                        <div class="linked-vehicle-list">
                            @for (int i = 0; i < Model.Vehicles.Count; i++)
                            {
                                <a class="linked-vehicle-item"
                                   asp-controller="CustomerVehicle"
                                   asp-action="EditCustomerVehicle"
                                   asp-route-CustomerVehicleId="@Model.Vehicles[i].Id"
                                   asp-route-userId="@userId">
                                    <span class="vehicle-avatar"><i class="bi bi-car-front"></i></span>
                                    <span>
                                        <strong>@Model.Vehicles[i].Make @Model.Vehicles[i].Model</strong>
                                        <small>@Model.Vehicles[i].VehicleRegistration</small>
                                    </span>
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-panel">
                            <i class="bi bi-car-front"></i>
                            No vehicles recorded for this customer.
                        </div>
                    }
                </div>

                <div class="workspace-panel linked-invoices-panel">
                    <div class="panel-heading">
                        <div>
                            <p class="eyebrow mb-1">Financial</p>
                            <h2>Invoices</h2>
                        </div>

                        <a class="btn btn-sm btn-primary"
                           asp-controller="VehicleInvoice"
                           asp-action="CustomerInvoices"
                           asp-route-customerId="@Model.Customer.Id">
                            <i class="bi bi-arrow-up-right"></i>
                        </a>
                    </div>

                    <div class="empty-panel">
                        <i class="bi bi-receipt"></i>
                        View customer invoices
                    </div>
                </div>
            }

            <div class="workspace-panel save-panel">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-check-lg me-2"></i>Save customer
                </button>

                <a class="btn btn-light w-100"
                   asp-action="GarageCustomersList"
                   asp-route-garageBusinessId="@garageBusinessId"
                   asp-route-userId="@userId">
                    Cancel
                </a>
            </div>
        </aside>
    </section>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
