<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GarageMate</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    @RenderSection("Styles", required: false)
</head>

<body>
    @{
        var garageBusinessId = TempData["GarageBusinessId"];
        var userId = TempData["userId"];
        TempData.Keep("GarageBusinessId");
        TempData.Keep("userId");
    }

    <header class="app-topbar">
        <nav class="navbar navbar-expand-lg navbar-light">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand app-brand"
                   asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/garagemate-logo.svg" asp-append-version="true" alt="GarageMate" />
                </a>

                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link @IsActive("Home","Index")"
                               asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i> Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @IsActive("GarageCustomers","GarageCustomersList")"
                               asp-controller="GarageCustomers" asp-action="GarageCustomersList"
                               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                                <i class="bi bi-people me-1"></i> Customers
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @IsActive("CustomerVehicle","CustomerVehicleList")"
                               asp-controller="CustomerVehicle" asp-action="CustomerVehicleList"
                               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                                <i class="bi bi-car-front me-1"></i> Vehicles
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link @IsActive("GarageBusiness","GarageBusinessDetail")"
                               asp-controller="GarageBusiness" asp-action="GarageBusinessDetail"
                               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                                <i class="bi bi-building-gear me-1"></i> Garage
                            </a>
                        </li>
                    </ul>

                    <div class="d-flex align-items-center gap-2">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="sidebar-label">Workspace</div>
            <a class="sidebar-link @IsActive("Home","Index")" asp-controller="Home" asp-action="Index">
                <i class="bi bi-speedometer2"></i><span>Dashboard</span>
            </a>
            <a class="sidebar-link @IsActive("GarageCustomers","GarageCustomersList")"
               asp-controller="GarageCustomers" asp-action="GarageCustomersList"
               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                <i class="bi bi-people"></i><span>Customers</span>
            </a>
            <a class="sidebar-link @IsActive("CustomerVehicle","CustomerVehicleList")"
               asp-controller="CustomerVehicle" asp-action="CustomerVehicleList"
               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                <i class="bi bi-car-front"></i><span>Vehicles</span>
            </a>
            <a class="sidebar-link @IsActive("GarageBusiness","GarageBusinessDetail")"
               asp-controller="GarageBusiness" asp-action="GarageBusinessDetail"
               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                <i class="bi bi-building-gear"></i><span>Garage profile</span>
            </a>

            <div class="sidebar-label mt-4">Create</div>
            <a class="sidebar-link"
               asp-controller="GarageCustomers" asp-action="DisplayAddGarageCustomersWithVehicle"
               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                <i class="bi bi-person-plus"></i><span>Customer</span>
            </a>
            <a class="sidebar-link"
               asp-controller="CustomerVehicle" asp-action="DisplayAddCustomerVehicle"
               asp-route-garageBusinessId="@garageBusinessId" asp-route-userId="@userId">
                <i class="bi bi-plus-circle"></i><span>Vehicle</span>
            </a>
        </aside>

        <div class="app-content">
            @if (TempData["Success"] is string successMsg)
            {
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-check-circle me-1"></i> @successMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] is string errorMsg)
            {
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i> @errorMsg
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <main role="main">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="app-footer">
        <div class="container-fluid px-3 px-lg-4 py-3 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
            <div class="text-muted small">
                &copy; @DateTime.Now.Year - GarageMate
            </div>
            <div class="small">
                <a class="text-decoration-none" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @RenderSection("Scripts", required: false)

    @functions {
        private string IsActive(string controller, string action)
        {
            var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
            var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

            return (string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase))
            ? "active fw-semibold"
            : "";
        }
    }
</body>
</html>
