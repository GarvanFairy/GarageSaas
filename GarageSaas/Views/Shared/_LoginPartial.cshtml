@using System
@using System.Security.Principal

@if (User.Identity.IsAuthenticated)
{
    var userName = TempData["userName"]?.ToString();
    TempData.Keep("userName");

    if (string.IsNullOrWhiteSpace(userName) || userName.Equals("unknown", StringComparison.OrdinalIgnoreCase))
    {
        userName = User.Identity.Name;
    }

    <div class="dropdown">
        <button class="btn btn-light account-menu dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <span class="account-avatar">@(!string.IsNullOrWhiteSpace(userName) ? userName.Substring(0, 1).ToUpperInvariant() : "G")</span>
            <span class="account-name">@userName</span>
        </button>
        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
            <li>
                <form method="get" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="EditProfile">
                    <button type="submit" class="dropdown-item">
                        <i class="bi bi-person-gear me-2"></i>Profile
                    </button>
                </form>
            </li>
            <li><hr class="dropdown-divider" /></li>
            <li>
                <form method="get" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignOut">
                    <button type="submit" class="dropdown-item">
                        <i class="bi bi-box-arrow-right me-2"></i>Sign out
                    </button>
                </form>
            </li>
        </ul>
    </div>
}
else
{
    <form method="get" asp-area="MicrosoftIdentity" asp-controller="Account" asp-action="SignIn">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-box-arrow-in-right me-1"></i> Sign in
        </button>
    </form>
}
