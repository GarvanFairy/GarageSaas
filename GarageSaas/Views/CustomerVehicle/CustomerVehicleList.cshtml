@using System.Collections.Generic
@using System.Linq
@model List<SignupAPI.Models.CustomerVehicleListVM>

@{
    ViewData["Title"] = "Vehicles";

    var garageBusinessId = TempData["GarageBusinessId"];
    var userId = TempData["userId"];
    TempData.Keep("GarageBusinessId");
    TempData.Keep("userId");

    var vehicleCount = Model?.Count ?? 0;
    var ownerCount = Model?
        .Where(v => !string.IsNullOrWhiteSpace(v.OwnerName))
        .Select(v => v.OwnerName)
        .Distinct()
        .Count() ?? 0;
    var registrationCount = Model?.Count(v => !string.IsNullOrWhiteSpace(v.VehicleRegistration)) ?? 0;
    var contactCount = Model?.Count(v =>
        !string.IsNullOrWhiteSpace(v.GarageCustomerMobileNumber) ||
        !string.IsNullOrWhiteSpace(v.GarageCustomerPhoneNumber) ||
        !string.IsNullOrWhiteSpace(v.GarageCustomerEmailAddress)) ?? 0;
}

<section class="page-title-row vehicle-page-header">
    <div>
        <p class="eyebrow mb-2">Vehicles</p>
        <h1>Vehicle register</h1>
        <p class="text-muted mb-0">Track customer-owned and garage-owned vehicles with owner contact details close at hand.</p>
    </div>

    <div class="page-actions">
        <a class="btn btn-primary"
           asp-controller="CustomerVehicle"
           asp-action="DisplayAddCustomerVehicle"
           asp-route-garageBusinessId="@garageBusinessId"
           asp-route-userId="@userId">
            <i class="bi bi-plus-lg me-2"></i>Add vehicle
        </a>

        <a class="btn btn-outline-secondary"
           asp-controller="GarageCustomers"
           asp-action="GarageCustomersList"
           asp-route-garageBusinessId="@garageBusinessId"
           asp-route-userId="@userId">
            <i class="bi bi-arrow-left me-2"></i>Customers
        </a>
    </div>
</section>

<section class="vehicle-summary-grid" aria-label="Vehicle summary">
    <div class="vehicle-summary-card">
        <span class="summary-icon summary-blue"><i class="bi bi-car-front"></i></span>
        <div>
            <span>Total vehicles</span>
            <strong id="totalCount">@vehicleCount</strong>
        </div>
    </div>
    <div class="vehicle-summary-card">
        <span class="summary-icon summary-teal"><i class="bi bi-person-badge"></i></span>
        <div>
            <span>Known owners</span>
            <strong>@ownerCount</strong>
        </div>
    </div>
    <div class="vehicle-summary-card">
        <span class="summary-icon summary-purple"><i class="bi bi-card-text"></i></span>
        <div>
            <span>Registrations</span>
            <strong>@registrationCount</strong>
        </div>
    </div>
    <div class="vehicle-summary-card">
        <span class="summary-icon summary-amber"><i class="bi bi-telephone"></i></span>
        <div>
            <span>Owner contacts</span>
            <strong>@contactCount</strong>
        </div>
    </div>
</section>

<section class="workspace-panel vehicle-table-panel">
    <div class="vehicle-toolbar">
        <div>
            <p class="eyebrow mb-1">Register</p>
            <h2>Vehicle records</h2>
        </div>

        <div class="vehicle-search">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input id="tableSearch" type="text" class="form-control"
                       placeholder="Search make, model, registration, owner..." />
            </div>
            <span class="badge text-bg-light border" id="rowCount"></span>
            <a class="btn btn-light"
               asp-controller="CustomerVehicle"
               asp-action="CustomerVehicleList"
               asp-route-garageBusinessId="@garageBusinessId"
               asp-route-userId="@userId">
                <i class="bi bi-arrow-clockwise"></i>
            </a>
        </div>
    </div>

    <div class="table-responsive vehicle-table-wrap">
        <table class="table table-hover align-middle mb-0 vehicle-table" id="vehiclesTable">
            <thead>
                <tr>
                    <th>Vehicle</th>
                    <th>Registration</th>
                    <th>Owner</th>
                    <th>Contact</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model == null || Model.Count == 0)
                {
                    <tr>
                        <td colspan="5">
                            <div class="vehicle-empty-state">
                                <span><i class="bi bi-car-front"></i></span>
                                <div>
                                    <strong>No vehicles found</strong>
                                    <p class="mb-0">Add a vehicle to start building the register.</p>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var vehicle in Model)
                    {
                        var vehicleName = $"{vehicle.VehicleMake} {vehicle.VehicleModel}".Trim();
                        var ownerName = string.IsNullOrWhiteSpace(vehicle.OwnerName) ? "No owner linked" : vehicle.OwnerName;

                        <tr>
                            <td>
                                <div class="vehicle-identity">
                                    <span class="vehicle-avatar"><i class="bi bi-car-front"></i></span>
                                    <div>
                                        <strong>@(string.IsNullOrWhiteSpace(vehicleName) ? "Unnamed vehicle" : vehicleName)</strong>
                                    </div>
                                </div>
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(vehicle.VehicleRegistration))
                                {
                                    <span class="registration-plate">@vehicle.VehicleRegistration</span>
                                }
                                else
                                {
                                    <span class="empty-value">No registration</span>
                                }
                            </td>

                            <td>
                                <div class="vehicle-owner">
                                    <strong>@ownerName</strong>
                                </div>
                            </td>

                            <td>
                                <div class="vehicle-contact-list">
                                    @if (!string.IsNullOrWhiteSpace(vehicle.GarageCustomerMobileNumber))
                                    {
                                        <span><i class="bi bi-phone"></i>@vehicle.GarageCustomerMobileNumber</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(vehicle.GarageCustomerPhoneNumber))
                                    {
                                        <span><i class="bi bi-telephone"></i>@vehicle.GarageCustomerPhoneNumber</span>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(vehicle.GarageCustomerEmailAddress))
                                    {
                                        <a href="mailto:@vehicle.GarageCustomerEmailAddress"><i class="bi bi-envelope"></i>@vehicle.GarageCustomerEmailAddress</a>
                                    }
                                    @if (string.IsNullOrWhiteSpace(vehicle.GarageCustomerMobileNumber) &&
                                         string.IsNullOrWhiteSpace(vehicle.GarageCustomerPhoneNumber) &&
                                         string.IsNullOrWhiteSpace(vehicle.GarageCustomerEmailAddress))
                                    {
                                        <span class="text-muted">No contact details</span>
                                    }
                                </div>
                            </td>

                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary"
                                   asp-controller="CustomerVehicle"
                                   asp-action="EditCustomerVehicle"
                                   asp-route-CustomerVehicleId="@vehicle.VehicleId"
                                   asp-route-userId="@userId"
                                   title="Edit vehicle">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <div class="vehicle-table-footer">
        <span class="text-muted small">
            Showing <span id="visibleCount"></span> of <span id="totalFooterCount"></span>
        </span>
    </div>
</section>

<div class="vehicle-card-list" id="vehiclesCards">
    @if (Model != null && Model.Any())
    {
        foreach (var vehicle in Model)
        {
            var vehicleName = $"{vehicle.VehicleMake} {vehicle.VehicleModel}".Trim();
            var ownerName = string.IsNullOrWhiteSpace(vehicle.OwnerName) ? "No owner linked" : vehicle.OwnerName;

            <article class="vehicle-mobile-card">
                <div class="vehicle-mobile-top">
                    <div class="vehicle-identity">
                        <span class="vehicle-avatar"><i class="bi bi-car-front"></i></span>
                        <div>
                            <strong>@(string.IsNullOrWhiteSpace(vehicleName) ? "Unnamed vehicle" : vehicleName)</strong>
                            <small>ID @vehicle.VehicleId</small>
                        </div>
                    </div>
                    <a class="btn btn-sm btn-outline-primary"
                       asp-controller="CustomerVehicle"
                       asp-action="EditCustomerVehicle"
                       asp-route-CustomerVehicleId="@vehicle.VehicleId"
                       asp-route-userId="@userId"
                       aria-label="Edit @vehicleName">
                        <i class="bi bi-pencil"></i>
                    </a>
                </div>

                <div class="vehicle-card-details">
                    @if (!string.IsNullOrWhiteSpace(vehicle.VehicleRegistration))
                    {
                        <span class="registration-plate">@vehicle.VehicleRegistration</span>
                    }
                    <span><i class="bi bi-person"></i>@ownerName</span>
                </div>

                <div class="vehicle-contact-list">
                    @if (!string.IsNullOrWhiteSpace(vehicle.GarageCustomerMobileNumber))
                    {
                        <span><i class="bi bi-phone"></i>@vehicle.GarageCustomerMobileNumber</span>
                    }
                    @if (!string.IsNullOrWhiteSpace(vehicle.GarageCustomerEmailAddress))
                    {
                        <a href="mailto:@vehicle.GarageCustomerEmailAddress"><i class="bi bi-envelope"></i>@vehicle.GarageCustomerEmailAddress</a>
                    }
                </div>
            </article>
        }
    }
    else
    {
        <article class="vehicle-mobile-card">
            <div class="vehicle-empty-state">
                <span><i class="bi bi-car-front"></i></span>
                <div>
                    <strong>No vehicles found</strong>
                    <p class="mb-0">Add a vehicle to start building the register.</p>
                </div>
            </div>
        </article>
    }
</div>

@section Scripts {
    <script>
        $(function () {
            const $rows = $("#vehiclesTable tbody tr").not(":has(td[colspan])");
            const $cards = $("#vehiclesCards .vehicle-mobile-card");

            $("#totalCount").text($rows.length);
            $("#totalFooterCount").text($rows.length);
            $("#visibleCount").text($rows.length);
            $("#rowCount").text($rows.length + " vehicles");

            $("#tableSearch").on("keyup", function () {
                const value = $(this).val().toLowerCase();
                let visible = 0;

                $rows.each(function () {
                    const show = $(this).text().toLowerCase().indexOf(value) > -1;
                    $(this).toggle(show);
                    if (show) visible++;
                });

                $cards.each(function () {
                    const show = $(this).text().toLowerCase().indexOf(value) > -1;
                    $(this).toggle(show);
                });

                $("#visibleCount").text(visible);
                $("#rowCount").text(visible + " vehicles");
            });
        });
    </script>
}
