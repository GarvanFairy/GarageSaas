@model SignupAPI.Models.VehicleAndCustomers

@{
    ViewData["Title"] = Model?.Vehicle?.Id > 0 ? "Edit Vehicle" : "Add Vehicle";

    string nctMonth = "", nctYear = "", taxMonth = "", taxYear = "";
    if (!string.IsNullOrWhiteSpace(Model?.Vehicle?.VehicleNCTDue))
    {
        var parts = Model.Vehicle.VehicleNCTDue.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) { nctMonth = parts[0].Trim(); nctYear = parts[1].Trim(); }
    }
    if (!string.IsNullOrWhiteSpace(Model?.Vehicle?.VehicleTaxDue))
    {
        var parts = Model.Vehicle.VehicleTaxDue.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2) { taxMonth = parts[0].Trim(); taxYear = parts[1].Trim(); }
    }

    string currentTransmission = (Model?.Vehicle?.VehicleTransmissionId.ToString() ?? "").Trim();
}

<div class="container-fluid px-0">
    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
        <div>
            <h2 class="mb-1">@ViewData["Title"]</h2>
            <div class="text-muted small">
                @(Model?.Vehicle?.Id > 0
                    ? $"Update details for {Model.Vehicle.VehicleRegistration}."
                    : "Add a vehicle and assign an owner.")
            </div>
        </div>

        <a class="btn btn-light mt-3 mt-md-0" asp-action="CustomerVehicleList">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @using (Html.BeginForm("AddUpdateCustomerVehicle", "CustomerVehicle", FormMethod.Post, new { id = "vehicleForm", autocomplete = "off" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.Vehicle.Id)

                <div class="row g-4">

                    <!-- Registration + Owner -->
                    <div class="col-12 col-md-4">
                        <label class="form-label">Registration</label>
                        <input class="form-control" id="txtRegistration"
                               value="@Model.Vehicle.VehicleRegistration"
                               placeholder="e.g. 12-D-12345" />
                    </div>

                    <div class="col-12 col-md-8">
                        <label class="form-label">Owner</label>
                        <select class="form-select" id="ddlVehicleOwner">
                            <option value="">-- Select owner --</option>
                            @foreach (var owner in Model.GarageVehicleOwnerList ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@owner.Value" selected="@(owner.Selected ? "selected" : null)">
                                    @owner.Text
                                </option>
                            }
                        </select>
                   

                        <!-- NEW CUSTOMER TOGGLE -->
                        <div class="form-check mt-2">
                            <input class="form-check-input" type="checkbox" id="chkNewCustomer">
                            <label class="form-check-label" for="chkNewCustomer">
                                Add new customer
                            </label>
                        </div>
                    </div>
                

                    <!-- Make / Model / Year -->
                    <div class="col-12 col-md-4">
                        <label class="form-label">Make</label>
                        <select class="form-select" id="ddlVehicleMake">
                            <option value="">-- Select make --</option>
                            @foreach (var make in Model.ListofVehicleMakes ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@make.Value"
                                        selected="@(make.Selected || make.Value == Model.Vehicle.VehicleMakeId.ToString() ? "selected" : null)">
                                    @make.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Model</label>
                        <select class="form-select" id="ddlVehicleModel">
                            <option value="">-- Select model --</option>
                            @foreach (var carModel in Model.ListofVehicleModels ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@carModel.Value"
                                        selected="@(carModel.Selected || carModel.Value == Model.Vehicle.VehicleModelId.ToString() ? "selected" : null)">
                                    @carModel.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Year</label>
                        <select class="form-select" id="ddlVehicleYears">
                            <option value="">-- Select year --</option>
                            @foreach (var y in Model.ListofVehicleYears ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@y.Value"
                                        selected="@(y.Selected || y.Value == Model.Vehicle.VehicleYearId.ToString() ? "selected" : null)">
                                    @y.Text
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Fuel / Transmission / Mileage -->
                    <div class="col-12 col-md-4">
                        <label class="form-label">Fuel type</label>
                        <select class="form-select" id="ddlFuelType">
                            <option value="">-- Select fuel --</option>
                            @foreach (var ft in Model.ListofFuelTypes ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@ft.Value"
                                        selected="@(ft.Selected || ft.Value == Model.Vehicle.VehicleFuelTypeId.ToString() ? "selected" : null)">
                                    @ft.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Transmission</label>
                        <select class="form-select" id="ddlTransmission">
                            <option value="">-- Select transmission type --</option>
                            @foreach (var tt in Model.ListofTransmissionTypes ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@tt.Value"
                                        selected="@(tt.Selected || tt.Value == Model.Vehicle.VehicleTransmissionId.ToString() ? "selected" : null)">
                                    @tt.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-12 col-md-4">
                        <label class="form-label">Mileage (KM)</label>
                        <select class="form-select" id="ddlMileage">
                            <option value="">-- Select mileage --</option>
                            @foreach (var m in Model.ListofMileages ?? Enumerable.Empty<SelectListItem>())
                            {
                                <option value="@m.Value"
                                        selected="@(m.Selected || m.Value == Model.Vehicle.VehicleMileageId.ToString() ? "selected" : null)">
                                    @m.Text
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Mileage Date -->
                    <div class="col-12 col-md-4">
                        <label class="form-label">Mileage date</label>
                        <input type="text" id="txtDate" class="form-control"
                               value="@(Model.Vehicle.VehicleMileageDate == default ? "" : Model.Vehicle.VehicleMileageDate.ToString("dd/MM/yyyy"))"
                               placeholder="dd/mm/yyyy" />
                    </div>

                    <!-- NCT -->
                    <div class="col-12 col-md-6">
                        <label class="form-label">NCT due</label>
                        <div class="row g-2">
                            <div class="d-flex gap-2">
                                <select class="form-select" id="ddlNCTMonth">
                                    @foreach (var mo in new[] { "JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC" })
                                    {
                                        <option value="@mo" selected="@(mo == nctMonth ? "selected" : null)">@mo</option>
                                    }
                                </select>
                            </div>
                            <div class="d-flex gap-2">
                                <select class="form-select" id="ddlNCTYear">
                                    @for (int y = DateTime.Now.Year; y <= DateTime.Now.Year + 7; y++)
                                    {
                                        <option value="@y" selected="@(y.ToString() == nctYear ? "selected" : null)">@y</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Tax -->
                    <div class="col-12 col-md-6">
                        <label class="form-label">Tax due</label>
                        <div class="row g-2">
                            <div class="d-flex gap-2">
                                <select class="form-select" id="ddlTaxMonth">
                                    @foreach (var mo in new[] { "JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC" })
                                    {
                                        <option value="@mo" selected="@(mo == taxMonth ? "selected" : null)">@mo</option>
                                    }
                                </select>
                            </div>
                            <div class="d-flex gap-2">
                                <select class="form-select" id="ddlTaxYear">
                                    @for (int y = DateTime.Now.Year; y <= DateTime.Now.Year + 7; y++)
                                    {
                                        <option value="@y" selected="@(y.ToString() == taxYear ? "selected" : null)">@y</option>
                                    }
                                </select>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <!-- NEW CUSTOMER PANEL -->
<div id="newCustomerPanel" class="col-12" style="display:none;">

    <div class="card bg-light border-0 mt-2">
        <div class="card-body">

            <h6 class="mb-3">New Customer Details</h6>

            <div class="row g-3">

                <div class="col-12 col-md-4">
                    <label class="form-label">First name</label>
                    <input class="form-control" id="txtNewCustomerForename" />
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">Surname</label>
                    <input class="form-control" id="txtNewCustomerSurname" />
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label">Mobile number</label>
                    <input class="form-control" id="txtNewCustomerMobile" />
                </div>

                                <div class="col-12 col-md-4">
                                    <label class="form-label">Email Address</label>
                                    <input class="form-control" id="txtNewCustomerEMail" />
                                </div>

            </div>

        </div>
    </div>
</div>

                <div class="d-flex flex-column flex-sm-row gap-2">
                    <button type="button" id="btnSavejs" class="btn btn-primary" onclick="SubmitVehicleCustomers();">
                        <i class="bi bi-check-lg me-1"></i> Save
                    </button>
                    <a class="btn btn-light" asp-action="CustomerVehicleList">Cancel</a>
                </div>

                <div id="statusArea" class="mt-3"></div>
            }
        </div>
    </div>
</div>


@section Scripts {
    <script type="text/javascript" src="~/js/moment.min.js"></script>
    <link rel="stylesheet" href="~/css/datepicker.css" />
    <script type="text/javascript" src="~/js/bootstrap-datepicker.js"></script>

    <script>
        $(function () {

            // Datepicker
            $('#txtDate').datepicker({
                autoclose: true,
                todayHighlight: true,
                format: "dd/mm/yyyy"
            });

            $('#chkNewCustomer').on('change', function () {

                if ($(this).is(':checked')) {

                    $('#newCustomerPanel').slideDown(150);

                    // Optional UX improvement:
                    $('#ddlVehicleOwner').prop('disabled', true);

                } else {

                    $('#newCustomerPanel').slideUp(150);
                    $('#ddlVehicleOwner').prop('disabled', false);
                }
            });

        });
    </script>

    <script type="text/javascript" src="~/js/CustomerVehicle/CustomerVehicle2.js"></script>
}
