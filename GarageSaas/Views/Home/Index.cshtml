@model GarageSaas.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var garageBusinessId = Model.GarageBusinessId;
    var userId = Model.UserId;
    var invoiceProgress = Model.InvoiceCount > 0 ? 72 : 12;
}

<section class="dashboard-header">
    <div>
        <p class="eyebrow mb-2">Dashboard</p>
        <h1>Good to see you@(string.IsNullOrWhiteSpace(Model.UserName) ? string.Empty : $", {Model.UserName}")</h1>
        <p class="text-muted mb-0">A clean view of customers, vehicles, invoices, and the work that keeps the garage moving.</p>
    </div>
    <div class="dashboard-actions">
        <a class="btn btn-primary"
           asp-controller="GarageCustomers"
           asp-action="DisplayAddGarageCustomersWithVehicle"
           asp-route-garageBusinessId="@garageBusinessId"
           asp-route-userId="@userId">
            <i class="bi bi-person-plus me-2"></i>Add customer
        </a>
        <a class="btn btn-outline-secondary"
           asp-controller="CustomerVehicle"
           asp-action="DisplayAddCustomerVehicle"
           asp-route-garageBusinessId="@garageBusinessId"
           asp-route-userId="@userId">
            <i class="bi bi-car-front me-2"></i>Add vehicle
        </a>
    </div>
</section>

<section class="metric-grid" aria-label="Garage summary">
    <div class="metric-card metric-blue">
        <div class="metric-card-top">
            <span>Customers</span>
            <div class="metric-icon"><i class="bi bi-people"></i></div>
        </div>
        <strong>@Model.CustomerCount</strong>
        <small><i class="bi bi-arrow-up-right"></i> Total customer records</small>
    </div>
    <div class="metric-card metric-teal">
        <div class="metric-card-top">
            <span>Vehicles</span>
            <div class="metric-icon"><i class="bi bi-car-front"></i></div>
        </div>
        <strong>@Model.VehicleCount</strong>
        <small><i class="bi bi-arrow-up-right"></i> Linked to this garage</small>
    </div>
    <div class="metric-card metric-purple">
        <div class="metric-card-top">
            <span>Invoices</span>
            <div class="metric-icon"><i class="bi bi-receipt"></i></div>
        </div>
        <strong>@Model.InvoiceCount</strong>
        <small><i class="bi bi-file-earmark-text"></i> Created invoices</small>
    </div>
    <div class="metric-card metric-rose">
        <div class="metric-card-top">
            <span>Outstanding</span>
            <div class="metric-icon"><i class="bi bi-cash-coin"></i></div>
        </div>
        <strong>@Model.OutstandingTotal.ToString("C0")</strong>
        <small><i class="bi bi-exclamation-circle"></i> Awaiting payment</small>
    </div>
</section>

<section class="dashboard-grid dashboard-grid-main">
    <div class="workspace-panel">
        <div class="panel-heading">
            <div>
                <p class="eyebrow mb-1">Workspace</p>
                <h2>Core workflows</h2>
            </div>
            <span class="status-pill"><i class="bi bi-circle-fill"></i> Live</span>
        </div>

        <div class="workflow-table">
            <a class="workflow-item"
               asp-controller="GarageCustomers"
               asp-action="GarageCustomersList"
               asp-route-garageBusinessId="@garageBusinessId"
               asp-route-userId="@userId">
                <span class="workflow-icon"><i class="bi bi-people"></i></span>
                <span>
                    <strong>Manage customers</strong>
                    <small>Find customer records, contact details, and linked vehicles.</small>
                </span>
                <span class="workflow-meta">@Model.CustomerCount records</span>
                <i class="bi bi-chevron-right"></i>
            </a>

            <a class="workflow-item"
               asp-controller="CustomerVehicle"
               asp-action="CustomerVehicleList"
               asp-route-garageBusinessId="@garageBusinessId"
               asp-route-userId="@userId">
                <span class="workflow-icon"><i class="bi bi-car-front"></i></span>
                <span>
                    <strong>Vehicle register</strong>
                    <small>Review registrations, ownership, and vehicle profiles.</small>
                </span>
                <span class="workflow-meta">@Model.VehicleCount vehicles</span>
                <i class="bi bi-chevron-right"></i>
            </a>

            <a class="workflow-item"
               asp-controller="GarageBusiness"
               asp-action="GarageBusinessDetail"
               asp-route-garageBusinessId="@garageBusinessId"
               asp-route-userId="@userId">
                <span class="workflow-icon"><i class="bi bi-building-gear"></i></span>
                <span>
                    <strong>Garage profile</strong>
                    <small>Keep business details ready for quotes and invoices.</small>
                </span>
                <span class="workflow-meta">Settings</span>
                <i class="bi bi-chevron-right"></i>
            </a>

            <a class="workflow-item"
               asp-controller="VehicleInvoice"
               asp-action="AddEdit"
               asp-route-id="0">
                <span class="workflow-icon"><i class="bi bi-receipt"></i></span>
                <span>
                    <strong>Create invoice</strong>
                    <small>Generate new invoices for customer work and services.</small>
                </span>
                <span class="workflow-meta">New invoice</span>
                <i class="bi bi-chevron-right"></i>
            </a>
        </div>
    </div>

    <aside class="dashboard-side">
        <div class="workspace-panel balance-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow mb-1">Payments</p>
                    <h2>Invoice snapshot</h2>
                </div>
            </div>

            <div class="balance-total">
                <span>Outstanding balance</span>
                <strong>@Model.OutstandingTotal.ToString("C0")</strong>
            </div>

            <div class="progress dashboard-progress" role="progressbar" aria-label="Invoice activity" aria-valuenow="@invoiceProgress" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar" style="width: @invoiceProgress%"></div>
            </div>

            <div class="invoice-summary">
                <span><i class="bi bi-receipt"></i> @Model.InvoiceCount invoices</span>
                <span><i class="bi bi-clock-history"></i> Review due balances</span>
            </div>
        </div>

        <div class="workspace-panel">
            <div class="panel-heading">
                <div>
                    <p class="eyebrow mb-1">Shortcuts</p>
                    <h2>Account tools</h2>
                </div>
            </div>

            <div class="quick-actions">
                <a class="btn btn-light"
                   asp-controller="Admin"
                   asp-action="Index">
                    <i class="bi bi-shield-check me-2"></i>Admin
                </a>
                <a class="btn btn-light" href="@Url.RouteUrl("OIDCMetadata")" target="_blank" rel="noreferrer">
                    <i class="bi bi-braces me-2"></i>OIDC metadata
                </a>
                <a class="btn btn-light" href="@Url.RouteUrl("JWKS")" target="_blank" rel="noreferrer">
                    <i class="bi bi-key me-2"></i>JWKS
                </a>
            </div>

            @if (!Model.HasGarageContext)
            {
                <div class="context-warning mt-3">
                    <i class="bi bi-exclamation-circle"></i>
                    Sign in to load your garage workspace.
                </div>
            }
        </div>
    </aside>
</section>
